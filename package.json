{
  "name": "seekharness",
  "version": "0.1.0",
  "description": "A minimal coding agent CLI",
  "type": "module",
  "bin": {
    "seekharness": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/tools/__tests__/glob.test.ts src/tools/__tests__/write.test.ts src/tools/__tests__/policy.test.ts src/tools/__tests__/grep.test.ts src/tools/__tests__/bash.test.ts src/eval/__tests__/run.test.ts",
    "e2e": "tsx scripts/e2e-tool-loop.ts",
    "eval": "tsx src/eval/run.ts",
    "eval:build": "python scripts/build-mini-set.py",
    "eval:pro": "tsx src/eval/run.ts datasets/pro.jsonl --concurrency 4",
    "eval:score": "python scripts/score.py",
    "eval:score:pro": "python scripts/score_pro.py"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.31",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
